{
  "name": "ditl",
  "version": "1.0.0",
  "description": "DITL — Developer-In-The-Loop Parameter Tuning Desktop App",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:css": "tailwindcss -i src/renderer/styles/input.css -o src/renderer/styles/output.css",
    "dev": "npm run build:css && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.ditl.app",
    "productName": "DITL",
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "glob": "^10.3.10",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^3.4.4"
  }
}
